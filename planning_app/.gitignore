# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env.local          # keep .env.example, ignore actual secrets
.env                # contains real secrets — never commit this

# ── ERP config (credentials — use .env instead) ──────────────────────────────
config/config.json

# ── Database ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Flask / Alembic ──────────────────────────────────────────────────────────
instance/
.webassets-cache

# ── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── IDE & OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Node (if any frontend tooling is added later) ────────────────────────────
node_modules/
npm-debug.log*
