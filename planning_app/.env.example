# Environment: development | testing | production
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-long-random-string

# Database
# Development default is SQLite (no server required) — omit DATABASE_URL to use it
# DATABASE_URL=sqlite:///planning_dev.db
# Switch to PostgreSQL when ready:
# DATABASE_URL=postgresql://planuser:planpass@localhost:5432/planning_db
# TEST_DATABASE_URL=postgresql://planuser:planpass@localhost:5432/planning_test_db

# JWT
JWT_SECRET_KEY=change-me-jwt-secret

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0

# Mail (for password reset)
MAIL_SERVER=smtp.yourserver.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=noreply@yourcompany.com
MAIL_PASSWORD=your-mail-password
MAIL_DEFAULT_SENDER=noreply@yourcompany.com

# App
APP_NAME=Planning Hub
# COMPANY_NAME is no longer used; site names are managed via the Sites admin panel

# ERP database (InterBase via ODBC — used for the "Refresh Data" feature)
ERP_DB_DRIVER=InterBase ODBC driver
ERP_DB_NAME=SERVER:c:\path\to\database.IB
ERP_DB_UID=SYSDBA
ERP_DB_PWD=your-erp-password
ERP_DB_CHARSET=NONE
